                              "name": "Text",
                              "fill": "#fff6f580",
                              "textGrowth": "fixed-width-height",
                              "width": 411.6700134277344,
                              "height": 46,
                              "content": "// Package scanner provides TCP utility functions\npackage main",
                              "lineHeight": 1.625,
                              "textAlignVertical": "middle",
                              "fontFamily": "Liberation Mono",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "XRvuR",
                              "name": "Text",
                              "fill": "#e60000ff",
                              "textGrowth": "fixed-width-height",
                              "width": 84.02999877929688,
                              "height": 114,
                              "content": "import (\n    \"fmt\"\n    \"net\"\n    \"sync\"\n)",
                              "lineHeight": 1.625,
                              "textAlignVertical": "middle",
                              "fontFamily": "Liberation Mono",
                              "fontSize": 14,
                              "fontWeight": "700"
                            },
                            {
                              "type": "text",
                              "id": "JSoZb",
                              "name": "Text",
                              "fill": "#fff6f580",
                              "textGrowth": "fixed-width-height",
                              "width": 495.69000244140625,
                              "height": 319,
                              "content": "// TODO: Implement timeout handling for stalled connections\nfunc worker(ports chan int, wg *sync.WaitGroup) {\n    for p := range ports {\n        address := fmt.Sprintf(\"scanme.nmap.org:%d\", p)\n        conn, err := net.Dial(\"tcp\", address)\n        if err != nil {\n            wg.Done()\n            continue\n        }\n        conn.Close()\n        fmt.Printf(\"%d open\\n\", p)\n        wg.Done()\n    }\n}",
                              "lineHeight": 1.625,
                              "textAlignVertical": "middle",
                              "fontFamily": "Liberation Mono",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        },
