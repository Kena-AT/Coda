{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Coda",
  "version": "1.0.0",
  "identifier": "com.coda.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Coda",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://asset.localhost; connect-src 'self' ipc: http://localhost:1420 https://generativelanguage.googleapis.com https://*.google.com; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Coda Systems",
    "copyright": "Copyright © 2026 Coda Systems",
    "shortDescription": "Premium snippet management",
    "longDescription": "The ultimate vault for your code intelligence, built with zero-trust security."
  }
}
